---
// Entrée de CV partagée par les sections Expériences et Formations :
// intitulé à gauche, dates dans une gouttière réservée à droite.
interface Props {
  title: string;
  org: string;
  dates: string;
  /** Ligne secondaire optionnelle (ex. stack d'une expérience). */
  detail?: string;
  /** Puces de responsabilités/réalisations optionnelles. */
  bullets?: string[];
  /** Largeur de la gouttière de dates (px). */
  dateWidth?: number;
  /** Marge basse de l'entrée (px). */
  gap?: number;
}

const {
  title,
  org,
  dates,
  detail,
  bullets = [],
  dateWidth = 120,
  gap = 24,
} = Astro.props as Props;
---

<div
  class="entry"
  style={`--dw:${dateWidth}px;margin-bottom:${gap}px;`}
>
  <div class="dates">{dates}</div>
  <div class="role">{title}</div>
  <div class="org">{org}</div>
  {detail && <div class="detail">{detail}</div>}
  {
    bullets.length > 0 && (
      <ul class="bullets">
        {bullets.map((b) => (
          <li>{b}</li>
        ))}
      </ul>
    )
  }
</div>

<style>
  .entry {
    position: relative;
    padding-right: calc(var(--dw) + 8px);
  }
  .dates {
    position: absolute;
    top: 2px;
    right: 0;
    width: var(--dw);
    text-align: right;
    font-size: 14px;
    color: var(--muted);
    line-height: 1.3;
  }
  .role {
    font-size: 17px;
    color: var(--ink);
    font-weight: 700;
    line-height: 1.3;
  }
  .org {
    font-style: italic;
    color: var(--muted);
    font-size: 16px;
    margin-top: 3px;
  }
  .detail {
    color: var(--muted);
    font-size: 14px;
    margin-top: 7px;
    line-height: 1.5;
  }
  .bullets {
    margin: 9px 0 0;
    padding-left: 1.1em;
    color: var(--muted);
    font-size: 15px;
    line-height: 1.6;
  }
  .bullets li {
    margin-bottom: 4px;
    text-wrap: pretty;
  }

  /* Mobile : la date passe en bandeau au-dessus du titre, plus de gouttière. */
  @media (max-width: 640px) {
    .entry {
      padding-right: 0;
    }
    .dates {
      position: static;
      width: auto;
      text-align: left;
      margin-bottom: 5px;
      font-size: 13px;
    }
  }
</style>
