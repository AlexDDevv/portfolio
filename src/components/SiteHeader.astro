---
import ContactLine from "@/components/ContactLine.astro";
import type { ContactItem } from "@/data/profile";

interface Props {
  name: string;
  subtitle: string;
  location: string;
  contactItems: ContactItem[];
}

const { name, subtitle, location, contactItems } = Astro.props as Props;
---

<header class="masthead">
  <h1>{name}</h1>
  <div class="subtitle">{subtitle}</div>
  <div class="contact">
    <ContactLine items={contactItems} />
  </div>
  <div class="location">{location}</div>
</header>

<style>
  .masthead {
    text-align: center;
    margin-top: 18px;
  }
  h1 {
    font-size: clamp(36px, 8vw, 54px);
    font-weight: 400;
    color: var(--ink);
    margin: 0;
    letter-spacing: -0.005em;
    line-height: 1.04;
  }
  .subtitle {
    margin-top: 14px;
    font-size: clamp(16px, 2.4vw, 18px);
    color: var(--muted);
  }
  .contact {
    margin-top: 14px;
  }
  .location {
    margin-top: 10px;
    font-size: 14px;
    color: var(--muted);
    letter-spacing: 0.01em;
  }
</style>
