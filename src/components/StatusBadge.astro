---
interface Props {
  label: string;
  /** Bordure plus marquée (en-tête de page projet). */
  strong?: boolean;
}

const { label, strong = false } = Astro.props as Props;
---

<span class:list={["badge", { strong }]}>{label}</span>

<style>
  .badge {
    font-size: 12px;
    color: var(--muted);
    font-variant: small-caps;
    letter-spacing: 0.05em;
    border: 1px solid var(--border);
    padding: 1px 8px;
    white-space: nowrap;
  }
  .badge.strong {
    font-size: 14px;
    color: var(--ink);
    border-color: var(--border-strong);
    padding: 1px 9px;
  }
</style>
