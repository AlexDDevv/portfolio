---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface GalleryItem {
  caption: string;
  image?: ImageMetadata;
}

interface Props {
  items: GalleryItem[];
  placeholder: string;
}

const { items, placeholder } = Astro.props as Props;
---

<div class="gallery">
  {
    items.map((shot) => (
      <figure>
        {shot.image ? (
          <Image
            src={shot.image}
            alt={shot.caption}
            widths={[320, 640, 960]}
            sizes="(max-width: 640px) 100vw, 360px"
            loading="lazy"
          />
        ) : (
          <div class="slot">
            <span class="slot-label">{placeholder}</span>
          </div>
        )}
        <figcaption>{shot.caption}</figcaption>
      </figure>
    ))
  }
</div>

<style>
  .gallery {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(258px, 1fr));
    gap: 22px;
  }
  figure {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 9px;
  }
  figure :global(img),
  .slot {
    width: 100%;
    aspect-ratio: 16 / 10;
    border: 1px solid var(--border);
    background: #fbfaf7;
    object-fit: cover;
  }
  .slot {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .slot-label {
    font-family: ui-monospace, "SFMono-Regular", Menlo, Consolas, monospace;
    font-size: 12px;
    color: var(--muted);
    letter-spacing: 0.02em;
  }
  figcaption {
    font-size: 13px;
    color: var(--muted);
    font-style: italic;
    text-align: center;
    text-wrap: pretty;
  }
</style>
