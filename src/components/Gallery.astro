---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface GalleryItem {
  caption: string;
  image?: ImageMetadata;
}

interface Props {
  items: GalleryItem[];
  placeholder: string;
}

const { items, placeholder } = Astro.props as Props;
---

<div class="gallery">
  {
    items.map((shot, i) =>
      shot.image ? (
        <figure>
          <button
            type="button"
            class="thumb"
            popovertarget={`lb-${i}`}
            aria-label={`Agrandir : ${shot.caption}`}
          >
            <Image
              src={shot.image}
              alt={shot.caption}
              widths={[320, 640, 960]}
              sizes="(max-width: 640px) 100vw, 360px"
              loading="lazy"
            />
          </button>
          <figcaption>{shot.caption}</figcaption>

          <div id={`lb-${i}`} popover="auto" class="lightbox">
            <button
              type="button"
              class="lightbox-close"
              popovertarget={`lb-${i}`}
              popovertargetaction="hide"
              aria-label="Fermer"
            >
              ×
            </button>
            <Image
              src={shot.image}
              alt={shot.caption}
              widths={[960, 1600]}
              sizes="94vw"
              loading="lazy"
            />
          </div>
        </figure>
      ) : (
        <figure>
          <div class="slot">
            <span class="slot-label">{placeholder}</span>
          </div>
          <figcaption>{shot.caption}</figcaption>
        </figure>
      ),
    )
  }
</div>

<style>
  .gallery {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(258px, 1fr));
    gap: 22px;
  }
  figure {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 9px;
  }
  .thumb {
    display: block;
    width: 100%;
    padding: 0;
    border: none;
    background: none;
    cursor: zoom-in;
    font: inherit;
  }
  .thumb :global(img) {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    border: 1px solid var(--border);
    background: #fbfaf7;
    transition: border-color 0.15s ease;
  }
  .thumb:hover :global(img),
  .thumb:focus-visible :global(img) {
    border-color: var(--ink);
  }
  .slot {
    width: 100%;
    aspect-ratio: 16 / 10;
    border: 1px solid var(--border);
    background: #fbfaf7;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .slot-label {
    font-family: ui-monospace, "SFMono-Regular", Menlo, Consolas, monospace;
    font-size: 12px;
    color: var(--muted);
    letter-spacing: 0.02em;
  }
  figcaption {
    font-size: 13px;
    color: var(--muted);
    font-style: italic;
    text-align: center;
    text-wrap: pretty;
  }

  /* Lightbox via l'API Popover : centrée et fermée nativement (clic extérieur / Échap). */
  .lightbox {
    /* Tailwind preflight remet margin:0 sur tous les éléments, ce qui écrase
       le centrage natif du popover (margin:auto) → on le rétablit ici. */
    position: fixed;
    inset: 0;
    margin: auto;
    width: fit-content;
    height: fit-content;
    border: none;
    padding: 0;
    background: transparent;
    max-width: 94vw;
    max-height: 94vh;
    overflow: visible;
  }
  .lightbox::backdrop {
    background: rgba(28, 28, 38, 0.82);
  }
  .lightbox :global(img) {
    display: block;
    max-width: 94vw;
    max-height: 88vh;
    width: auto;
    height: auto;
    border: 1px solid var(--border-strong);
    background: var(--bg);
  }
  .lightbox-close {
    position: absolute;
    top: -16px;
    right: -16px;
    width: 38px;
    height: 38px;
    border-radius: 50%;
    border: 1px solid var(--border-strong);
    background: var(--bg);
    color: var(--ink);
    font-size: 22px;
    line-height: 1;
    cursor: pointer;
    font-family: var(--font-serif);
  }
  .lightbox-close:hover {
    border-color: var(--ink);
  }
</style>
