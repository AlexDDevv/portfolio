---
import SeoMeta from "@/components/SeoMeta.astro";
import "@/styles/global.css";

interface Props {
  title: string;
  description: string;
  canonical?: string;
  noindex?: boolean;
}

const { title, description, canonical, noindex } = Astro.props as Props;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />

    <SeoMeta
      title={title}
      description={description}
      canonical={canonical}
      noindex={noindex}
    />
  </head>

  <body>
    <slot />
  </body>
</html>
